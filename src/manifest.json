{
  "manifest_version": 3,
  "name": "Sushidash",
  "version": "1.0.0",
  "description": "寿司打の起動を速くする拡張機能",
  "host_permissions": [
    "https://sushida.net/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://sushida.net/*"
      ],
      "js": [
        "patcher.js",
        "enhance.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}